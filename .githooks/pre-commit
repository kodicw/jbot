#!/nix/store/sfvyavxai6qvzmv9p9x6mp4wwdz4v41m-bash-interactive-5.3p9/bin/bash
set -euo pipefail

echo "[pre-commit] Running checks..."

# 1. Nix formatting
echo "  -> nixfmt --check"
if ! find . -name "*.nix" -not -path "*/.*" -exec nixfmt --check {} +; then
  echo ""
  echo "  FAIL: Nix formatting issues found."
  echo "  Run 'nixfmt *.nix' to fix, then re-stage."
  exit 1
fi

# 2. statix lint
echo "  -> statix check"
if ! statix check .; then
  echo ""
  echo "  FAIL: statix found Nix anti-patterns."
  echo "  Run 'statix fix .' to auto-fix where possible."
  exit 1
fi

# 3. Python formatting
echo "  -> ruff format --check"
if ! ruff format --check .; then
  echo ""
  echo "  FAIL: Python formatting issues found."
  echo "  Run 'ruff format .' to fix, then re-stage."
  exit 1
fi

# 4. Ruff linting
echo "  -> ruff check"
if ! ruff check .; then
  echo ""
  echo "  FAIL: Ruff found linting errors."
  echo "  Run 'ruff check --fix .' to auto-fix where possible."
  exit 1
fi

# 5. ShellCheck
echo "  -> shellcheck"
if command -v shellcheck >/dev/null 2>&1; then
  if ! shellcheck scripts/*.sh .githooks/*; then
    echo ""
    echo "  FAIL: ShellCheck found issues in bash scripts."
    exit 1
  fi
else
  echo "  (skipped: shellcheck not found)"
fi

echo "[pre-commit] All checks passed!"

